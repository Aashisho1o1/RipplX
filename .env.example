# SEC requires a User-Agent header for all EDGAR access.
# finwatch refuses to run any EDGAR command without it.
SEC_USER_AGENT="Your Name your-email@example.com"

# SQLite database location.
FINWATCH_DB=./data/finwatch.db

# LLM model strings (litellm format). Set after the golden-set bake-off (Phase 5).
FINWATCH_MODEL_EXTRACT=
FINWATCH_MODEL_REASON=

# Provider credentials stay in the environment or may be entered session-only in RipplX.
# Example for OpenAI-backed LiteLLM model strings:
OPENAI_API_KEY=

# EOD price source (free CSV endpoint, no key required).
FINWATCH_PRICE_SOURCE=stooq
