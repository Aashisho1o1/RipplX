# SEC requires a User-Agent header for all EDGAR access.
# finwatch refuses to run any EDGAR command without it.
SEC_USER_AGENT="Your Name your-email@example.com"

# SQLite database location.
FINWATCH_DB=./data/finwatch.db

# One production model for the launch path (litellm format). Accepted prefixes, each
# mapping to one fixed endpoint:
#   z-ai/<model>       Zhipu GLM via z.ai's Anthropic-compatible endpoint (ZAI_API_KEY)
#   openrouter/<model> any model OpenRouter proxies              (OPENROUTER_API_KEY)
#   openai/<model>     OpenAI direct                             (OPENAI_API_KEY)
# Default: GLM 5.2 via z.ai — it drove the tool harness reliably in testing where
# deepseek-v4-flash did not (it produces conforming tool calls and exact quotes).
# Alternatives: FINWATCH_MODEL=openrouter/deepseek/deepseek-v4-flash  (cheaper, less reliable)
#               FINWATCH_MODEL=openai/gpt-4o-mini                     (OpenAI direct)
FINWATCH_MODEL=z-ai/glm-5.2
# Optional stronger finance Skeptic; defaults to FINWATCH_MODEL when blank.
FINWATCH_SKEPTIC_MODEL=

# Provider credential for CLI/local mode. Hosted browser users enter their own matching
# key after sign-in; hosted requests never share these environment credentials.
# z-ai/* reads ZAI_API_KEY; openrouter/* reads OPENROUTER_API_KEY; openai/* reads OPENAI_API_KEY.
ZAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Required only when serving on a non-loopback address (the Docker hosted alpha).
# FINWATCH_AUTH_SECRET signs 30-day login and CSRF cookies; generate at least 32 random characters.
FINWATCH_AUTH_SECRET=
FINWATCH_ALLOWED_HOSTS=your-alpha.example.com
RESEND_API_KEY=
FINWATCH_EMAIL_FROM="RipplX <login@your-domain.example>"
