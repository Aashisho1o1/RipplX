# SEC requires a User-Agent header for all EDGAR access.
# finwatch refuses to run any EDGAR command without it.
SEC_USER_AGENT="Your Name your-email@example.com"

# SQLite database location.
FINWATCH_DB=./data/finwatch.db

# One production model for the launch path (litellm format). The launch path accepts
# the openai/ (OpenAI direct) or openrouter/ (OpenRouter) prefix; OpenRouter proxies
# cheap models like deepseek/gemini through its own fixed endpoint — no base-URL
# override needed. Confirm the exact model slug at https://openrouter.ai/models .
# Default: deepseek v4 flash via OpenRouter (cheap, fast, strong reasoning).
# Alternative: FINWATCH_MODEL=openai/gpt-4o-mini  (OpenAI direct)
FINWATCH_MODEL=openrouter/deepseek/deepseek-v4-flash

# Provider credential (environment, or entered session-only in RipplX; never persisted).
# openrouter/* reads OPENROUTER_API_KEY; openai/* reads OPENAI_API_KEY.
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Required only when serving on a non-loopback address (the Docker hosted alpha).
# Use a randomly generated value of at least 32 characters and terminate TLS before the container.
FINWATCH_AUTH_TOKEN=
FINWATCH_ALLOWED_HOSTS=your-alpha.example.com
