# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtualenv / tooling caches
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Environment / secrets (never commit real credentials)
.env

# finwatch runtime data (DB + on-disk EDGAR cache are regenerable).
# Root-anchored so they never swallow PACKAGED data dirs like
# src/finwatch/demo/data/ (hatchling excludes git-ignored files from the wheel).
/data/
/cache/
*.db
*.db-journal
*.db-wal

# OS / editor cruft
.DS_Store
*.swp
.vscode/
.idea/
